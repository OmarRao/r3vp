# Default: normalise line endings to LF in the repo
* text=auto eol=lf

# Shell scripts must stay LF even on Windows checkout
*.sh text eol=lf

# Windows batch files need CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — no line-ending conversion
*.png binary
*.jpg binary
*.pem binary
*.key binary
*.p12 binary
*.ova binary
*.vmdk binary
